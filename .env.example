# --- Desarrollo local ---
# Vacío = el front llama a rutas relativas /api y Vite las proxifica a localhost:3001
# VITE_API_URL=http://localhost:3001

# Plaid (opcional): muestra la pestaña "Bancos" y el hook de Plaid.
# VITE_ENABLE_PLAID=true
# El servidor Express también lee este archivo: puedes poner aquí (o en server/.env):
# ENABLE_PLAID=true
# PLAID_CLIENT_ID=...
# PLAID_SECRET=...
# PLAID_ENV=sandbox

# --- Build para Firebase Hosting (producción) ---
# En Hosting NO hay proxy: debes definir la URL pública de tu API Express (Render, Fly, VPS, etc.)
# Copia este archivo a .env y rellena antes de: npm run build && npm run deploy:firebase
# VITE_API_URL=https://tu-api.example.com
# Tras desplegar con render.yaml, suele ser: https://hogarfinance-api.onrender.com

# Firebase Web (Consola → rueda → Configuración del proyecto → Tus apps → Web)
# Activa "Correo/contraseña" (y opcionalmente "Anónimo") en Authentication → Sign-in method.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# Realtime Database (solo si más adelante usas getDatabase() en el cliente)
# VITE_FIREBASE_DATABASE_URL=https://controldgastos-default-rtdb.firebaseio.com
