DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
JWT_SECRET=cambia-esto-por-algo-largo-y-aleatorio
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# --- Plaid (opcional; requiere npm install en /server) ---
ENABLE_PLAID=true
PLAID_CLIENT_ID=tu_client_id
PLAID_SECRET=tu_secret
PLAID_ENV=sandbox

# Opcional: validar ID tokens del cliente (Auth anónima). Sin esto, /api/auth/register usa IDs locales (solo desarrollo).
# En Firebase Console → Proyecto → Cuentas de servicio → Generar nueva clave privada → pega el JSON en una sola línea:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Alternativa local: GOOGLE_APPLICATION_CREDENTIALS=C:\ruta\clave.json
